datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String         @id @default(uuid())
  walletAddress   String         @unique
  ensName         String?
  username        String?        @unique
  avatarUrl       String?
  referralCode    String         @unique
  referredBy      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  // Relations
  positions       Position[]
  trades          Trade[]
  comments        Comment[]
  likes           CommentLike[]
  notifications   Notification[]
  referrals       User[]         @relation("UserReferrals")
  referrer        User?          @relation("UserReferrals", fields: [referredBy], references: [walletAddress])
  watchlist       Market[]       @relation("Watchlist")
}

model Market {
  id               String         @id @default(uuid())
  contractAddress  String         @unique
  title            String
  description      String
  category         String         // e.g. "CRYPTO", "POLITICS", etc. (stored as String for SQLite compatibility)
  type             String         // e.g. "YES_NO", etc.
  status           String         @default("ACTIVE") // e.g. "ACTIVE", "RESOLVED"
  bannerUrl        String?
  rules            String
  endDate          DateTime
  oracleSource     String
  tags             String         // Stored as comma-separated tags for SQLite compatibility
  resolutionMethod String
  resolutionValue  String?
  resolvedAt       DateTime?
  creatorAddress   String
  
  // Financial metrics
  totalVolume      Decimal        @default(0)
  openInterest     Decimal        @default(0)
  tvl              Decimal        @default(0)
  
  // Relations
  outcomes         Outcome[]
  trades           Trade[]
  positions        Position[]
  comments         Comment[]
  watchlistedBy    User[]         @relation("Watchlist")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Outcome {
  id               String         @id @default(uuid())
  marketId         String
  market           Market         @relation(fields: [marketId], references: [id])
  name             String         // e.g., "YES", "NO"
  price            Decimal        // Current price in USD / Collateral (0.0000 - 1.0000)
  totalShares      Decimal        @default(0)
  
  positions        Position[]
  trades           Trade[]
}

model Position {
  id               String         @id @default(uuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id])
  marketId         String
  market           Market         @relation(fields: [marketId], references: [id])
  outcomeId        String
  outcome          Outcome        @relation(fields: [outcomeId], references: [id])
  sharesOwned      Decimal
  averageBuyPrice  Decimal
  unrealizedPnl    Decimal        @default(0)
  realizedPnl      Decimal        @default(0)
  updatedAt        DateTime       @updatedAt
  
  @@unique([userId, outcomeId])
}

model Trade {
  id               String         @id @default(uuid())
  txHash           String         @unique
  userId           String
  user             User           @relation(fields: [userId], references: [id])
  marketId         String
  market           Market         @relation(fields: [marketId], references: [id])
  outcomeId        String
  outcome          Outcome        @relation(fields: [outcomeId], references: [id])
  type             String         // "BUY" or "SELL"
  amount           Decimal        // Collateral spent
  shares           Decimal        // Shares bought/sold
  pricePaid        Decimal        // Price per share
  feePaid          Decimal
  timestamp        DateTime       @default(now())
}

model Comment {
  id               String         @id @default(uuid())
  marketId         String
  market           Market         @relation(fields: [marketId], references: [id])
  userId           String
  user             User           @relation(fields: [userId], references: [id])
  content          String
  parentId         String?
  parent           Comment?       @relation("CommentReplies", fields: [parentId], references: [id])
  replies          Comment[]      @relation("CommentReplies")
  likes            CommentLike[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model CommentLike {
  id               String         @id @default(uuid())
  commentId        String
  comment          Comment        @relation(fields: [commentId], references: [id])
  userId           String
  user             User           @relation(fields: [userId], references: [id])
  
  @@unique([commentId, userId])
}

model Notification {
  id               String         @id @default(uuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id])
  title            String
  message          String
  read             Boolean        @default(false)
  type             String         // "MARKET_ENDING", "RESOLUTION", "TRADE_FILLED", "REWARD", "TRENDING"
  link             String?
  createdAt        DateTime       @default(now())
}
